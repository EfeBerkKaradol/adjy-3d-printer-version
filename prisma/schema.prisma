generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ AUTH ============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  fullName      String?
  phone         String?
  image         String?
  role          Role      @default(USER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  cartItems     CartItem[]
  customizations Customization[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============ ADDRESS ============

model Address {
  id          String      @id @default(cuid())
  userId      String
  title       String
  addressLine String
  city        String
  state       String?
  country     String      @default("TR")
  postalCode  String?
  isDefault   Boolean     @default(false)
  type        AddressType @default(SHIPPING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ============ PRODUCT ============

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  basePrice      Decimal  @db.Decimal(10, 2)
  categoryId     String
  modelFileUrl   String?
  thumbnailUrl   String?
  gallery        Json?
  printTimeEst   Int?     // minutes
  materialType   String?
  materialWeight Decimal? @db.Decimal(8, 2) // grams
  isActive       Boolean  @default(true)
  featured       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category       Category        @relation(fields: [categoryId], references: [id])
  parameters     Parameter[]
  variants       ProductVariant[]
  reviews        Review[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  customizations Customization[]
  tags           ProductTag[]

  @@index([categoryId])
  @@index([slug])
  @@index([isActive])
  @@map("products")
}

model Parameter {
  id             String  @id @default(cuid())
  productId      String
  name           String
  displayName    String
  type           ParameterType
  minValue       Float?
  maxValue       Float?
  defaultValue   String
  step           Float?
  unit           String? // mm, cm, etc.
  affectsPrice   Boolean @default(false)
  priceFormula   String? // e.g., "base * (value / 100)"
  affectsGeometry Boolean @default(true)
  validationRules Json?
  sortOrder      Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("parameters")
}

model ProductVariant {
  id            String  @id @default(cuid())
  productId     String
  variantName   String
  priceModifier Decimal @db.Decimal(10, 2) @default(0)
  sku           String? @unique
  stockQty      Int     @default(0)
  attributes    Json?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  products ProductTag[]

  @@map("tags")
}

model ProductTag {
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

// ============ CUSTOMIZATION ============

model Customization {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  parameters Json     // { height: 150, width: 100, color: "#FF5733" }
  previewUrl String?
  stlFileUrl String?
  createdAt  DateTime @default(now())

  product    Product     @relation(fields: [productId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("customizations")
}

// ============ CART ============

model CartItem {
  id              String   @id @default(cuid())
  userId          String
  productId       String
  customizationId String?
  quantity        Int      @default(1)
  addedAt         DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product        @relation(fields: [productId], references: [id])
  customization Customization? @relation(fields: [customizationId], references: [id])

  @@map("cart_items")
}

// ============ ORDER ============

model Order {
  id            String        @id @default(cuid())
  userId        String
  orderNumber   String        @unique
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  totalAmount   Decimal       @db.Decimal(10, 2)
  discountAmount Decimal      @db.Decimal(10, 2) @default(0)
  taxAmount     Decimal       @db.Decimal(10, 2) @default(0)
  shippingCost  Decimal       @db.Decimal(10, 2) @default(0)
  grandTotal    Decimal       @db.Decimal(10, 2)
  currency      String        @default("TRY")
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  items         OrderItem[]
  address       OrderAddress?
  history       OrderHistory[]
  shipment      Shipment?

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String
  customizationId String?
  productName     String  // snapshot
  productSku      String?
  customParams    Json?   // snapshot
  quantity        Int
  unitPrice       Decimal @db.Decimal(10, 2)
  lineTotal       Decimal @db.Decimal(10, 2)
  printStatus     PrintStatus @default(QUEUED)
  stlFileUrl      String?

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product        @relation(fields: [productId], references: [id])
  customization Customization? @relation(fields: [customizationId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderAddress {
  id              String @id @default(cuid())
  orderId         String @unique
  shippingLine1   String
  shippingLine2   String?
  shippingCity    String
  shippingState   String?
  shippingZip     String?
  shippingCountry String @default("TR")
  billingLine1    String
  billingLine2    String?
  billingCity     String
  billingState    String?
  billingZip      String?
  billingCountry  String @default("TR")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_addresses")
}

model OrderHistory {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  changedBy String   // userId or "system"
  notes     String?
  metadata  Json?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_history")
}

model Shipment {
  id             String    @id @default(cuid())
  orderId        String    @unique
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  status         String    @default("pending")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shipments")
}

// ============ REVIEW ============

model Review {
  id               String   @id @default(cuid())
  productId        String
  userId           String
  rating           Int      // 1-5
  title            String?
  comment          String?
  images           Json?    // string array
  verifiedPurchase Boolean  @default(false)
  helpfulCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@map("reviews")
}

// ============ ENUMS ============

enum Role {
  USER
  ADMIN
  SELLER
}

enum AddressType {
  SHIPPING
  BILLING
}

enum ParameterType {
  SLIDER
  DROPDOWN
  COLOR
  TEXT
  NUMBER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PRINTING
  QUALITY_CHECK
  PACKAGING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PrintStatus {
  QUEUED
  PRINTING
  DONE
  FAILED
}
