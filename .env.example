# ===========================================
# ADJY 3D Printer - Environment Variables
# ===========================================

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=verify-full"
DIRECT_DATABASE_URL="postgresql://user:password@host/dbname?sslmode=verify-full"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="https://your-app.vercel.app"

# Redis (Upstash)
REDIS_URL="rediss://default:token@host:6379"

# App
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# SMTP (Email - optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Cloudinary (Image Upload - optional)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# iyzico Payment (optional for testing)
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# Google Analytics 4 (optional)
NEXT_PUBLIC_GA4_ID=""

# Meta Pixel (optional)
NEXT_PUBLIC_META_PIXEL_ID=""

# Ozel baski (musteri STL) siparis bildirimlerinin gonderilecegi e-posta
CUSTOM_ORDER_NOTIFY_EMAIL="efeberkkaradol@gmail.com"

# Vercel Web Analytics API (admin dashboard ziyaret istatistikleri, optional)
# Token: vercel.com -> Account Settings -> Tokens
# Project ID: Project Settings -> General
# Team ID: kisisel hesapta bos birakin
VERCEL_API_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""
